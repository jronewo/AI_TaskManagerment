# Mặc định: KHÔNG set VITE_API_BASE_URL → dev server proxy /api → http://localhost:5283
# (tránh "Failed to fetch" do cross-origin / API chưa bật).
#
# Nếu muốn gọi thẳng API (không proxy), bật dòng sau và sửa URL cho đúng:
# VITE_API_BASE_URL=http://localhost:5283
#
# Đổi cổng proxy (ít khi cần):
# VITE_API_PROXY_TARGET=http://localhost:5283
